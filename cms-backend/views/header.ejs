<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - SMC</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-blue: #1a3b8c;
      --dark-blue: #111827;
      --gold: #f59e0b;
      --light-bg: #f3f4f6;
      --sidebar-width: 260px;
    }
    body { 
      min-height: 100vh; 
      display: flex; 
      flex-direction: column; 
      font-family: 'Inter', sans-serif;
      background-color: var(--light-bg);
    }
    .sidebar { 
      width: var(--sidebar-width); 
      background: linear-gradient(180deg, var(--dark-blue) 0%, var(--primary-blue) 100%);
      color: white; 
      min-height: 100vh; 
      padding-top: 20px; 
      position: fixed; 
      left: 0; 
      top: 0; 
      box-shadow: 4px 0 10px rgba(0,0,0,0.1);
      z-index: 1000;
    }
    .sidebar-brand {
      display: flex;
      align-items: center;
      padding: 20px;
      margin-bottom: 10px;
      gap: 15px;
    }
    .logo-box {
      width: 55px;
      height: 55px;
      background-color: rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px;
      flex-shrink: 0;
    }
    .logo-box img {
      max-width: 100%;
      max-height: 100%;
      filter: brightness(0) invert(1);
    }
    .brand-text {
      display: flex;
      flex-direction: column;
    }
    .brand-title {
      color: #ffffff;
      font-weight: 700;
      font-size: 1.2rem;
      line-height: 1.2;
    }
    .brand-subtitle {
      color: #8fa0c0;
      font-size: 0.85rem;
      font-weight: 500;
      margin-top: 2px;
    }
    .sidebar a { 
      color: #cbd5e1; 
      text-decoration: none; 
      padding: 14px 24px; 
      display: block; 
      font-weight: 500;
      transition: all 0.3s ease;
      border-left: 4px solid transparent;
    }
    .sidebar a i {
      width: 24px;
      text-align: center;
      margin-right: 10px;
    }
    .sidebar a:hover, .sidebar a.active { 
      color: white; 
      background: rgba(255,255,255,0.1); 
      border-left: 4px solid var(--gold);
    }
    .main-content { 
      margin-left: var(--sidebar-width); 
      padding: 30px; 
      flex: 1; 
    }
    .topbar { 
      background: white; 
      padding: 15px 30px; 
      box-shadow: 0 2px 15px rgba(0,0,0,0.04); 
      display: flex; 
      justify-content: space-between; 
      align-items: center; 
      margin-bottom: 30px; 
      border-radius: 12px;
    }
    .topbar h5 {
      font-weight: 700;
      color: var(--primary-blue);
    }
    .card {
      border: none;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
      transition: transform 0.3s;
    }
    .card:hover {
      transform: translateY(-5px);
    }
    .bg-primary { background: linear-gradient(135deg, #2563eb, var(--primary-blue)) !important; }
    .bg-success { background: linear-gradient(135deg, #10b981, #059669) !important; }
    .bg-warning { background: linear-gradient(135deg, #f59e0b, #d97706) !important; }
    .bg-info    { background: linear-gradient(135deg, #0ea5e9, #0284c7) !important; }
  </style>
</head>
<body>
  
  <div class="sidebar">
    <div class="sidebar-brand">
      <div class="logo-box">
        <img src="/images/logo.png" alt="SMC Logo">
      </div>
      <div class="brand-text">
        <div class="brand-title">SMC Admin</div>
        <div class="brand-subtitle">Admin Panel</div>
      </div>
    </div>
    <a href="/admin/dashboard" class="active"><i class="fa-solid fa-gauge"></i> Dashboard</a>
    <a href="/admin/banners"><i class="fa-regular fa-image"></i> Quản lý Banner</a>
    <a href="/admin/about"><i class="fa-solid fa-address-card"></i> Về chúng tôi</a>
    <a href="/admin/industries"><i class="fa-solid fa-industry"></i> Lĩnh vực</a>
    <a href="/admin/services"><i class="fa-solid fa-concierge-bell"></i> Dịch vụ</a>
    <a href="/admin/projects"><i class="fa-solid fa-building"></i> Dự án & Đối tác</a>
    <a href="/admin/news"><i class="fa-regular fa-newspaper"></i> Tin tức & Hình ảnh</a>
    <a href="/admin/forms"><i class="fa-solid fa-wpforms"></i> Đăng ký khảo sát</a>
    <a href="/admin/contact"><i class="fa-solid fa-phone"></i> Thông tin liên hệ</a>
  </div>

  <div class="main-content">
    <div class="topbar">
      <h5 class="m-0"><%= typeof title !== 'undefined' ? title : 'Tổng quan' %></h5>
      <div class="d-flex align-items-center">
        <div class="d-flex align-items-center me-4">
          <div style="width: 35px; height: 35px; border-radius: 50%; background: var(--gold); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 10px;">A</div>
          <span class="fw-bold">Admin</span>
        </div>
        <a href="/admin/logout" class="btn btn-outline-danger" style="border-radius: 8px;"><i class="fa-solid fa-arrow-right-from-bracket"></i> Thoát</a>
      </div>
    </div>
    <div class="content-wrapper">
